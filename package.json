    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "wrangler": "^4.105.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.0",
    "concurrently": "^9.0.1",
